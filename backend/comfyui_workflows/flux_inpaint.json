{
  "_comment": "Adversaria AI — Flux inpainting workflow for localized regeneration (nudge one element, preserve the rest). UX differentiator from full rerolls.",
  "prompt": {
    "1": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "flux1-dev-fp8.safetensors"
      }
    },
    "2": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "__IMAGE_PATH__",
        "upload": "image"
      }
    },
    "3": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "__MASK_PATH__",
        "upload": "image"
      }
    },
    "4": {
      "class_type": "ImageToMask",
      "inputs": {
        "image": ["3", 0],
        "channel": "red"
      }
    },
    "5": {
      "class_type": "VAEEncodeForInpaint",
      "inputs": {
        "pixels": ["2", 0],
        "vae": ["1", 2],
        "mask": ["4", 0],
        "grow_mask_by": 6
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "__PROMPT__",
        "clip": ["1", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "watermark, text, blurry, low quality, deformed",
        "clip": ["1", 1]
      }
    },
    "8": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["1", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["5", 0],
        "seed": "__SEED__",
        "steps": 25,
        "cfg": 7.0,
        "sampler_name": "dpmpp_2m",
        "scheduler": "karras",
        "denoise": 0.85
      }
    },
    "9": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["8", 0],
        "vae": ["1", 2]
      }
    },
    "10": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["9", 0],
        "filename_prefix": "adversaria_inpaint"
      }
    }
  }
}
